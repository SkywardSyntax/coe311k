    "import numpy as np\n",
    "\n",
    "running_sum = 0\n",
    "\n",
    "for i in range (0,10000):\n",
    "    \n",
    "    running_sum = running_sum + 4*(((-1)**i)/((2*i)+1))\n",
    "    \n",
    "    if (i%100):\n",
    "        print(running_sum)\n",
    "        print(\"Error: \", np.pi-running_sum, \"\\n\")\n",
    "        \n",
    "        \n",
    "        "
